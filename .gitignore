# Universal base .gitignore for scaffoldrack repos.
# Append type-specific sections below this when scaffolding.

# ─────────────────────────────────────────────────────────
# Workspace
# ─────────────────────────────────────────────────────────
tmp/*
!tmp/.gitkeep

*.zip
*.tar
*.tar.gz
*.tgz

# ─────────────────────────────────────────────────────────
# Secrets
# ─────────────────────────────────────────────────────────
.env
.env.*
!.env.example
*.local
*.pem
*.key
*.crt
*.cer
id_rsa
id_ed25519
credentials
credentials.json

# API keys and tokens
*apikey*
*api_key*
*.token

# ─────────────────────────────────────────────────────────
# OS junk
# ─────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
.directory
.Trash-*

# ─────────────────────────────────────────────────────────
# Editors and IDEs
# ─────────────────────────────────────────────────────────
.vscode/
*.code-workspace
.idea/
*.iml
*.swp
*.swo
*~
Session.vim

# ─────────────────────────────────────────────────────────
# Backups and temp files
# ─────────────────────────────────────────────────────────
*.bak
*.backup
*.old
*.orig
*.rej

# Logs
logs/
*.log

# ─────────────────────────────────────────────────────────
# Ansible
# ─────────────────────────────────────────────────────────

# Retry files from failed plays
*.retry

# Vault password files (NEVER commit these)
.vault_pass
.vault_pass.txt
vault_password
vault_password.txt
*vault_pass*

# Per-host overrides that should stay local
host_vars/*.local
group_vars/*.local

# Ansible Galaxy installed roles (committed via requirements.yml instead)
roles/external/
collections/ansible_collections/

# Local fact cache
.facts_cache/
fact_cache/

# Compiled binaries from custom modules
*.pyc

# Molecule test artifacts (if used)
.molecule/

# ─────────────────────────────────────────────────────────
# bootstrap repo specific
# ─────────────────────────────────────────────────────────

# Old session-handoff documents that may have landed here in error
conversation-summary*.md
